+def guard_scripted_training(args):
+    env = args.get('env', {})
+    train = args.get('train', {})
+    scripted = bool(int(env.get('scripted_opponent', 0) or 0))
+    learning_active = float(train.get('learning_rate', 0.0) or 0.0) > 1e-9
+    if not scripted or not learning_active:
+        return
+
+    # LOCAL PATCH (bloodbowl-rl): the native/CUDA backend has the same
+    # scripted-row contamination risk as torch, but its selfplay/rollout path
+    # has no tested row-filter here. Block active native scripted training
+    # until that backend gets its own gated implementation.
+    if not args.get('slowly'):
+        raise RuntimeError(
+            'scripted_opponent with learning_rate > 1e-9 is unsafe on the '
+            'native/CUDA backend: bot-side sampled actions are replaced by '
+            'c_step and the native PPO path does not implement scripted row '
+            'exclusion. Use --slowly for the torch row-filter, or keep '
+            'learning_rate <= 1e-9 for frozen eval.')
 
