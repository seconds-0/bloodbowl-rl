+# ===========================================================================
+# LOCAL PATCH (bloodbowl-rl): BC-regularized PPO — human-imitation anchor.
+#
+# Motivation (DECISIONS.md D27): 10B steps of selfplay PPO eroded the
+# BC-pretrained human prior (BC-init beat BC-final head-to-head). Fix is the
+# AlphaStar-style anchor: an auxiliary masked cross-entropy on human
+# (obs, mask, action) pairs added to the PPO loss DURING RL, so the prior
+# cannot be pruned as wasted entropy.
+#
+# Config ([train] in config/bloodbowl.ini):
+#   bc_coef        weight of the BC term (0.0 = OFF, bit-identical upstream)
+#   bc_pairs_dir   dir of .bbp shards (tools/bb_lockstep.c --dump-pairs)
+#   bc_batch       human pairs sampled per PPO minibatch
+#   bc_coef_anneal 1 = cosine-decay bc_coef to 10% over total_timesteps
+#
+# All .bbp records are preloaded to device tensors at create time
+# (24K records x ~1.3KB ~= 32MB). The BC forward uses zero initial recurrent
+# state, matching training/bc_pretrain.py v0 exactly. bc_loss/bc_acc/bc_coef
+# are exported through the losses dict to the dashboard and wandb.
+#
+# When bc_coef == 0.0 this patch performs no tensor ops and consumes no RNG —
+# behavior is bit-identical to unpatched upstream.
+#
+# NOTE: the BC term calls policy.forward_eval, which under DDP is bound to
+# the unwrapped module (create_pufferl), bypassing gradient sync — the BC
+# anchor is single-process-only for now (all bloodbowl runs are).
+#
+# Patch copy: training/torch_pufferl_bcreg.patch (reapply after a vendor
+# re-clone; see .claude/skills/puffer-env-dev/SKILL.md).
+# ===========================================================================
+import struct
+
+_BC_MAGIC, _BC_VERSIONS, _BC_HEADER_LEN = b'BBP1', (1, 2), 16
+
+def _bc_resolve_pairs_dir(path):
+    '''Resolve a relative bc_pairs_dir against the CWD first, then the repo
+    root above vendor/PufferLib (puffer train usually runs from there).'''
+    if os.path.isabs(path) or os.path.isdir(path):
+        return path
+    here = os.path.realpath(__file__)
+    root = here
+    for _ in range(4):  # pufferlib/ -> PufferLib/ -> vendor/ -> <repo root>
+        root = os.path.dirname(root)
+    cand = os.path.join(root, path)
+    return cand if os.path.isdir(cand) else path
+
+def _bc_load_pairs(pairs_dir, obs_size, act_sizes, device):
+    '''Preload every .bbp shard (format: tools/bb_lockstep.c BBP1 header +
+    packed records; layout mirrors training/bc_pretrain.py REC_DTYPE) into
+    (obs u8, mask bool, target i64[3]) device tensors.'''
+    paths = sorted(glob.glob(os.path.join(pairs_dir, '*.bbp')))
+    if not paths:
+        raise FileNotFoundError(
+            f'bc_coef > 0 but no .bbp shards in {pairs_dir} — run '
+            'validation/extract_pairs.py or set --train.bc-pairs-dir')
+    shards, hdr = [], None
+    for p in paths:
+        with open(p, 'rb') as f:
+            raw = f.read()
+        magic, ver, osz, msz = struct.unpack('<4sIII', raw[:_BC_HEADER_LEN])
+        if magic != _BC_MAGIC or ver not in _BC_VERSIONS:
+            raise ValueError(f'{p}: bad .bbp header {magic!r} v{ver}')
+        if hdr is None:
+            hdr = (osz, msz)
+        elif (osz, msz) != hdr:
+            raise ValueError(f'{p}: .bbp header mismatch across shards')
+        rec_dtype = np.dtype([
+            ('replay', '<u4'), ('cmd', '<u4'), ('agent', 'u1'), ('pad', 'u1', (3,)),
+            ('obs', 'u1', (osz,)), ('mask', 'u1', (msz,)),
+            ('type', 'u1'), ('arg', 'u1'), ('sq', '<u2'),
+        ])
+        shards.append(np.frombuffer(raw[_BC_HEADER_LEN:], dtype=rec_dtype))
+    osz, msz = hdr
+    if osz != obs_size:
+        raise ValueError(f'.bbp obs size {osz} != vec obs size {obs_size}')
+    if msz != int(sum(act_sizes)):
+        raise ValueError(f'.bbp mask size {msz} != sum(act_sizes) {tuple(act_sizes)}')
+    recs = np.concatenate(shards)
+    obs = torch.from_numpy(np.ascontiguousarray(recs['obs'])).to(device)
+    mask = torch.from_numpy(np.ascontiguousarray(recs['mask'])).to(device).bool()
+    tgt = torch.stack([
+        torch.from_numpy(recs['type'].astype(np.int64)),
+        torch.from_numpy(recs['arg'].astype(np.int64)),
+        torch.from_numpy(recs['sq'].astype(np.int64)),
+    ], dim=1).to(device)
+    return obs, mask, tgt
+
+def _bc_loss_and_acc(policy, obs, mask, tgt, act_sizes, device):
+    '''Masked per-head CE at zero recurrent state — numerically identical to
+    training/bc_pretrain.py masked_losses/forward_heads (v0 iid treatment).
+    Returns (summed CE loss [with graph], exact-match accuracy [no graph]).'''
+    state = policy.initial_state(obs.shape[0], device=device)
+    logits, _values, _state = policy.forward_eval(obs, state)
+    off, loss, exact = 0, None, None
+    for h, n in enumerate(act_sizes):
+        m = mask[:, off:off + n]
+        off += n
+        lg = logits[h].masked_fill(~m, -1e9)
+        ce = torch.nn.functional.cross_entropy(lg, tgt[:, h])
+        loss = ce if loss is None else loss + ce
+        hit = lg.argmax(dim=1) == tgt[:, h]
+        exact = hit if exact is None else (exact & hit)
+    return loss, exact.float().mean()
+# ======================= END LOCAL PATCH (BC-reg PPO) ======================
+
