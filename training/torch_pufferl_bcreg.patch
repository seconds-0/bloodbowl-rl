+def apply_action_mask(logits, mask, act_sizes):
+    """LOCAL PATCH (bloodbowl-rl): restrict per-head logits to the env's
+    legal-action mask before sampling/scoring. The BC corpus and the bc_acc
+    aux loss are mask-restricted, and the CUDA backend samples masked — the
+    torch backend sampling RAW logits made every BC-anchored run play via
+    decode fallback (measured illegal_frac 1.000). Rows with an all-zero
+    head slice (shouldn't happen; the env asserts >=1 legal bit per head)
+    are left unmasked as a guard.
+
+    logits: list of per-head tensors [(B,n0),(B,n1),...]; mask: (B, sum(n))
+    uint8/bool; returns new list."""
+    out = []
+    off = 0
+    for h, n in enumerate(act_sizes):
+        mh = mask[:, off:off + n].bool()
+        off += n
+        ok = mh.any(dim=-1, keepdim=True)
+        out.append(logits[h].masked_fill((~mh) & ok, float('-inf')))
+    return out
+
+
