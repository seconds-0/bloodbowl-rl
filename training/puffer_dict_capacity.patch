+    // Hard runtime check: the upstream assert() compiles out under NDEBUG,
+    // turning a too-small create_dict() into silent heap corruption that
+    // surfaces as "free(): corrupted unsorted chunks" epochs later (seen
+    // when my_log key count outgrew vec_log's capacity). Fail loudly here.
+    if (dict->size >= dict->capacity) {
+        fprintf(stderr,
+                "dict_set: capacity %d exceeded adding key '%s' — bump "
+                "create_dict() at the call site\n",
+                dict->capacity, key);
+        abort();
+    }
     dict->items[dict->size].key = key;
     dict->items[dict->size].value = value;
     dict->size++;
